{
  "name": "@jsx6/nodditor",
  "version": "1.0.40",
  "type": "module",
  "description": "JSX6 blocky nodes code editor",
  "main": "index.js",
  "types": "dist/index.d.ts",
  "unpkg": "cjs/index.js",
  "module": "./index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./cjs/index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "dist",
    "src"
  ],
  "scripts": {
    "start": "node src_build/build.js --dev",
    "build": "node src_build/build.js",
    "prepublishOnly": "echo 'ready to publish'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hrgdavor/jsx6.git"
  },
  "keywords": [
    "UI",
    "jsx",
    "node",
    "code",
    "blocky"
  ],
  "author": "Davor hrg",
  "license": "MIT",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/hrgdavor/jsx6/blob/master/LICENSE.md"
    }
  ],
  "bugs": {
    "url": "https://hrgdavor/jsx6/issues"
  },
  "homepage": "https://hrgdavor.github.io/jsx6/",
  "devDependencies": {
    "esbuild": "catalog:",
    "@jsx6/build": "workspace:*",
    "@jsx6/jsx-dev-runtime": "workspace:*",
    "@jsx6/jsx-runtime": "workspace:*",
    "@jsx6/signal": "workspace:*",
    "@jsx6/signal-dom": "workspace:*",
    "@jsx6/w": "workspace:*",
    "@trivago/prettier-plugin-sort-imports": "catalog:",
    "live-server": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@jsx6/jsx6": "workspace:*",
    "@jsx6/w": "workspace:*",
    "@jsx6/signal": "workspace:*",
    "@jsx6/jsx-runtime": "workspace:*",
    "@jsx6/dom-observer": "workspace:*"
  }
}
