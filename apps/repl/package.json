{
  "name": "@jsx6/repl",
  "version": "1.8.18",
  "type": "module",
  "description": "JSX6 REPL engine",
  "main": "index.js",
  "unpkg": "cjs/index.js",
  "module": "esm/index.js",
  "exports": {
    ".": {
      "require": "./cjs/index.js",
      "default": "./esm/index.js"
    }
  },
  "files": [
    "index.js",
    "src",
    "esm",
    "cjs"
  ],
  "scripts": {
    "start": "node src_build/build.js --dev",
    "build": "node src_build/build.js",
    "format": "prettier --write \"./src/**/*.{js,jsx,json}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hrgdavor/jsx6.git"
  },
  "keywords": [
    "UI",
    "jsx",
    "repl"
  ],
  "author": "Davor hrg",
  "license": "MIT",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/hrgdavor/jsx6/blob/master/LICENSE.md"
    }
  ],
  "bugs": {
    "url": "https://hrgdavor/jsx6/issues"
  },
  "homepage": "https://hrgdavor.github.io/jsx6/",
  "devDependencies": {
    "esbuild": "catalog:",
    "@jsx6/build": "workspace:*",
    "@jsx6/jsx-dev-runtime": "workspace:*",
    "@trivago/prettier-plugin-sort-imports": "catalog:",
    "prettier": "catalog:",
    "@jsx6/editor-monaco": "workspace:*",
    "live-server": "catalog:",
    "@babel/standalone": "~7.18.12",
    "@happy-dom/global-registrator": "catalog:",
    "@types/bun": "catalog:",
    "bun-types": "catalog:"
  },
  "dependencies": {
    "@jsx6/jsx6": "workspace:*",
    "@jsx6/jsx-runtime": "workspace:*",
    "@jsx6/dom-observer": "workspace:*",
    "@jsx6/signal": "workspace:*",
    "@jsx6/signal-dom": "workspace:*",
    "@jsx6/w": "workspace:*",
    "babel-plugin-syntax-jsx": "~6.18.0",
    "babel-plugin-jsx-simple": "~1.6.0",
    "markdown-it": "~14.1.0",
    "mulmd": "~0.7.0",
    "perfect-scrollbar": "~1.5.5"
  }
}
